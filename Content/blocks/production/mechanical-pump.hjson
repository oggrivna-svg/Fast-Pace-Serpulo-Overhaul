{
  // Скорость выкачки (в оригинале 0.11 или 6.6 ед/сек)
  // Увеличиваем до 0.3 (это 18 ед/сек) — почти в 3 раза быстрее!
  "pumpAmount": 0.3,

  // Прочность (чуть добавим живучести)
  "health": 80,

  // Вместимость жидкости внутри самой помпы
  "liquidCapacity": 40,

  // Цена (сделаем максимально доступной для старта)
  "requirements": [
    { "item": "copper", "amount": 8 },    // Было 15
    { "item": "metaglass", "amount": 5 }  // Было 10
  ]
}
